<!DOCTYPE html>
<html lang="sv">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/stylesheets/basket.css">
   
    <title>Varukorgen</title>
</head>
<body>
    <%- include('partials/layout/header') %>
    <main>

 <section class="basket-page">
    <h1 class="kassan">Varukorg</h1>

    <% if (basketItems.length === 0) { %>
      <p class="empty-basket">Din varukorg är tom.</p>
    <% } else { %>

      <div class="basket-table-wrapper">
        <table class="basket-table">
          <thead>
            <tr>
              <th>Produkt</th>
              <th>Antal</th>
              <th>Pris</th>
              <th>Totalt</th>
              <th>Antal</th>
            </tr>
          </thead>

          <tbody>
            <% basketItems.forEach(item => { %>
              <tr>
                <td><%= item.name %></td>
                <td><%= item.quantity %></td>
                <td><%= item.price %> kr</td>
                <td><%= item.total %> kr</td>
                <td>
                  <div class="antal-container">
                    <form action="/basket/update" method="POST">
                      <input type="hidden" name="productId" value="<%= item.id %>">
                      <select name="quantity" onchange="this.form.submit()">
                        <option value="1" <%= item.quantity === 1 ? 'selected' : '' %>>1</option>
                        <option value="2" <%= item.quantity === 2 ? 'selected' : '' %>>2</option>
                        <option value="3" <%= item.quantity === 3 ? 'selected' : '' %>>3</option>
                        <option value="4" <%= item.quantity === 4 ? 'selected' : '' %>>4</option>
                      </select>
                    </form>

                    <form action="/basket/remove" method="POST">
                      <input type="hidden" name="productId" value="<%= item.id %>">
                      <button class="trash-button" type="submit" aria-label="Ta bort produkt">
                        <img src="/images/icons/trash.svg" alt="">
                      </button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <div class="checkout-button-wrapper">
        <a href="/checkout" class="checkout-button">Köp</a>
      </div>

    <% } %>
  
    </main>
              <%- include('partials/layout/footer') %>
</body>
</html>