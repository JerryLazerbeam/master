<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/stylesheets/header.css">
</head>

<body>
    <header>
        <div class="header-container">
            <img class="header-logo" src="/images/ChatGPT Image 20 mars 2026 18_47_47.png" alt="">
            <div class="search-row">
                <div class="search-wrapper">
                    <img src="/images/icons/search.svg" alt="search-icon" class="searchicon">
                    <input class="search" type="search" placeholder="Sök produkt">
                </div>

                <div class="icons">
                    <a href="#"><img src="/images/icons/suit-heart-fill.svg" alt="favorit"></a>
                    <a href="#"><img src="/images/icons/basket2-fill.svg" alt="kundkorg"></a>
                    <a href="#"><img src="/images/icons/box-arrow-in-right.svg" alt="login"></a>
                </div>
            </div>
        </div>
        <nav class="menyrad">
                <ul>
                    <% categories.forEach(category=> { %>
                        <li>
                            <a href="#">
                                <%= category.name %>
                            </a>
                        </li>
                        <% }) %>
                </ul>
            </nav>
        </nav>
    </header>

</body>

</html>