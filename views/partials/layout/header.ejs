<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/stylesheets/header.css">
</head>

<body>
    <header>
        <div class="header-container">
            <a href="/">
                <img class="header-logo" src="/images/ChatGPT Image 20 mars 2026 18_47_47.png" alt="header img">
            </a>
            <div class="search-row">
                <form action="/search" method="GET" class="search-wrapper">
                    <img src="/images/icons/search.svg" alt="search-icon" class="searchicon" autocomplete="off">
                    <input id="searchInput" class="search" type="search" placeholder="Sök produkt" name="q"
                        autocomplete="off">
                    <div id="searchDropdown" class="search-dropdown"></div>
                </form>
                <div class="icons">
                    <a href="/favorites"><img src="/images/icons/suit-heart-fill.svg" alt="favorit"></a>
                    <a href="/basket"><img src="/images/icons/basket2-fill.svg" alt="kundkorg"></a>
                    <% if (user) { %>
                        <% const tooltipText = user.role === 'admin' ? 'Inloggad som admin' : `Inloggad som ${user.firstname || user.email}`; %>
                        <button class="account-button" type="button" onclick="toggleMenu()" aria-label="<%= tooltipText %>">
                            <img class="logout-icon" src="/images/icons/person-circle.svg" alt="">
                            <span class="account-tooltip" role="tooltip"><%= tooltipText %></span>
                        </button>

                        <div id="dropdownMenu" class="hidden">
                            <a href="/logout">Logga ut</a>
                            <a href="/account">Mitt konto</a>
                        </div>
                    <% } else { %>
                    <a href="/login"><img src="/images/icons/box-arrow-in-right.svg" alt="login"></a>
                    <% } %>
                    

                    <% if (!user) { %>
                        <% } else { %>
                            <% if (user.role==='admin' ) { %>
                                <a href="/admin/products">
                                    <img src="/images/icons/admin_panel_settings_24dp_000000_FILL0_wght400_GRAD0_opsz24.svg" alt="admin">
                                </a>
                                <% } %>
                                    <% } %>

                </div>
            </div>
        </div>
        <nav class="menyrad">
            <ul class="menu-list">
                <% categories.forEach(category=> { %>
                    <li class="menu-item">
                        <a href="<%= category.link %>">
                            <%= category.name %>
                        </a>
                        <% if (category.subcategories && category.subcategories.length> 0) { %>
                            <ul class="dropdown-menu">
                                <% category.subcategories.forEach(subcategory=> { %>
                                    <li class="subcategory">
                                        <a href="<%= subcategory.link %>">
                                            <%= subcategory.name %>
                                        </a>
                                    </li>
                                    <% }); %>
                            </ul>
                            <% } %>
                    </li>
                    <% }) %>
            </ul>
        </nav>
        <div class="accordion mobile-accordion" id="categoryAccordion">
            <% categories.forEach((category, index) => { %>
          <div class="accordion-item">
                <button 
                  class="accordion-button collapsed" 
                  type="button"
                  data-bs-toggle="collapse"
                  data-bs-target="#collapse-<%= index %>">
                  
                  <%= category.name %>
                </button>
              
          

              <% if (category.subcategories && category.subcategories.length > 0) { %>
              <div id="collapse-<%= index %>" class="accordion-collapse collapse">
                <div class="accordion-body">
                  <% category.subcategories.forEach(sub => { %>
                    <a href="<%= sub.link %>" class="accordion-link">
                      <%= sub.name %>
                    </a>
                  <% }) %>
                </div>
              </div>
              <% } else { %>
              <!-- Om ingen subcategory → gör hela knappen till länk -->
              <script>
                document.addEventListener("DOMContentLoaded", () => {
                  const btn = document.querySelector('[data-bs-target="#collapse-<%= index %>"]');
                  if (btn) {
                    btn.addEventListener("click", () => {
                      window.location.href = "<%= category.link %>";
                    });
                    }
                  });
              </script>
              <% } %>

              <% }) %>
          </div>
        </div>  
        
    </header>
<script>
function toggleMenu() {
  const menu = document.getElementById("dropdownMenu");
  menu.classList.toggle("hidden");
}
document.addEventListener("click", function (event) {
  const menu = document.getElementById("dropdownMenu");
  const accountButton = document.querySelector(".account-button");

  if (!menu || !accountButton) return;

  const clickedInsideMenu = menu.contains(event.target);
  const clickedAccountButton = accountButton.contains(event.target);

  if (!clickedInsideMenu && !clickedAccountButton) {
    menu.classList.add("hidden");
  }
});
</script>

      <script src="/javascripts/search.js"></script>
</body>

</html>
